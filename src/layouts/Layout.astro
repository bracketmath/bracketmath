---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, canonical, noindex = false } = Astro.props;
const siteName = 'BracketMath';
const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;
// Compute the canonical URL.
//
// The site is hosted on Cloudflare Pages, which serves every page at `/path/`
// (trailing slash) and 307-redirects `/path` → `/path/`. If we emit the canonical
// WITHOUT the trailing slash, Google fetches the no-slash version, follows the
// 307, lands on the with-slash page, reads the canonical pointing at no-slash,
// and reports the result as a "Redirect error" — refusing to index. This was the
// bug that left 214 of 215 URLs unindexed on Day 2 (15 May 2026). The fix is to
// make the canonical match the served URL exactly: always trailing-slash. Combined
// with `trailingSlash: 'always'` in astro.config.mjs, this guarantees alignment
// between sitemap entries, served URLs, and canonical tags.
const rawPath = canonical ? new URL(canonical).pathname : Astro.url.pathname;
const normalisedPath = rawPath.endsWith('/') ? rawPath : `${rawPath}/`;
const canonicalUrl = new URL(normalisedPath, Astro.site ?? 'https://bracketmath.co.uk').toString();

---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Self-hosted fonts (see global.css). `preload` only the two regular-weight    -->
  <!-- faces that appear above the fold to keep critical-path bytes small.           -->
  <link rel="preload" href="/fonts/inter-400-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-600-latin.woff2" as="font" type="font/woff2" crossorigin />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
