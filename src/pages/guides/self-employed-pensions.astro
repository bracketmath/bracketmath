---
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { simulateRetirement } from '../../lib/montecarlo/simulate';

const money = (n: number) => '£' + Math.round(n).toLocaleString('en-GB');
const pct = (n: number) =>
  (n * 100).toLocaleString('en-GB', { maximumFractionDigits: 1 }) + '%';

// Build-time Monte Carlo: smaller path count keeps the build fast while still
// giving statistically meaningful figures for the prose (±~1.5pp on probabilities).
function mc(opts: Parameters<typeof simulateRetirement>[0]) {
  return simulateRetirement({ ...opts, numPaths: 2_000, seed: 1 });
}

// Optimiser persona: 40yo, £100k pot, contributing £15k/yr, retire 65, target £30k/yr real.
const a = mc({
  currentAge: 40, retirementAge: 65, currentPot: 100_000,
  annualContribution: 15_000, targetRetirementIncome: 30_000, equityWeight: 0.7,
});

// Optimiser persona, more aggressive: same but £25k/yr contribution.
const b = mc({
  currentAge: 40, retirementAge: 65, currentPot: 100_000,
  annualContribution: 25_000, targetRetirementIncome: 30_000, equityWeight: 0.7,
});

// Pre-retiree persona: 55yo, £400k pot, £5k/yr top-up, retire 65, target £28k/yr real.
const c = mc({
  currentAge: 55, retirementAge: 65, currentPot: 400_000,
  annualContribution: 5_000, targetRetirementIncome: 28_000, equityWeight: 0.5,
});

const today = new Date().toISOString().slice(0, 10);
const url = 'https://bracketmath.co.uk/guides/self-employed-pensions';
