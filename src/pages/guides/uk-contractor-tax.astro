---
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { optimiseSalaryDividend } from '../../lib/optim/salary-dividend';
import { niSelfEmployed } from '../../lib/tax/ni';
import { incomeTax } from '../../lib/tax/income-tax';

/* ------------------------------------------------------------------ */
/* Build-time engine drives every numeric claim below.                 */
/* ------------------------------------------------------------------ */

const money = (n: number) =>
  '£' + Math.round(n).toLocaleString('en-GB');
const pct = (n: number) =>
  (n * 100).toLocaleString('en-GB', { maximumFractionDigits: 1 }) + '%';

/** Sole-trader net cash at profit P (rUK). */
function soleTrader(profits: number) {
  const ni = niSelfEmployed(profits);
  const it = incomeTax(profits, {});
  return {
    grossProfits: profits,
    tax: it.tax,
    ni: ni.ni,
    netCash: profits - it.tax - ni.ni,
    effectiveRate: (it.tax + ni.ni) / profits,
    marginalRate: it.marginalRate + ni.marginalRate,
  };
}

/** Ltd Co (post-optimisation, cash-only view at pensionWeight=0). */
function ltdCo(profits: number) {
  const res = optimiseSalaryDividend({
    profits,
    age: 40,
    pensionWeight: 0, // cash-only optimum for the headline comparison
    salaryStep: 100,
    pensionStep: 500,
  });
  const o = res.cashOptimum;
  return {
    grossProfits: profits,
    salary: o.salary,
    dividend: o.dividend,
    netCash: o.netCash,
    totalTax: o.totalTaxAndNI,
    effectiveRate: o.effectiveTotalTaxRate,
    cashSavingsVsRuleOfThumb: res.cashSavingsVsRuleOfThumb,
  };
}

/** Ltd Co (with pension as a CT-deductible employer contribution). */
function ltdCoWealth(profits: number) {
  const res = optimiseSalaryDividend({
    profits,
    age: 40,
    pensionWeight: 1.0,
    salaryStep: 100,
    pensionStep: 500,
  });
  return res;
}

// Worked rows used in the comparison table below.
const st50 = soleTrader(50_000);
const st80 = soleTrader(80_000);
const st140 = soleTrader(140_000);

const lc50 = ltdCo(50_000);
const lc80 = ltdCo(80_000);
const lc140 = ltdCo(140_000);

const w140 = ltdCoWealth(140_000); // headline £140k Ltd Co case with pension

const today = new Date().toISOString().slice(0, 10);
const url = 'https://bracketmath.co.uk/guides/uk-contractor-tax';
