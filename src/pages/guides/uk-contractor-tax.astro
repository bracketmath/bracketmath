            </tr>
            <tr>
              <td class="py-2 pr-4">{money(140_000)}</td>
              <td class="py-2 pr-4">{money(st140.netCash)}</td>
              <td class="py-2 pr-4">{money(lc140.netCash)}</td>
              <td class="py-2 pr-4 text-[color:var(--color-success)]">+{money(lc140.netCash - st140.netCash)}</td>
            </tr>
