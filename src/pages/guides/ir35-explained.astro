const money = (n: number) => '£' + Math.round(n).toLocaleString('en-GB');
const pct = (n: number) =>
  (n * 100).toLocaleString('en-GB', { maximumFractionDigits: 1 }) + '%';

function run(dayRate: number) {
  return compareIR35({
    dayRate,
    billableDays: 220,
    annualBusinessExpenses: 3_000,
    umbrellaFeeAnnual: 1_500,
    pensionPercent: 0.05,
    age: 40,
  });
}

const r400 = run(400);
const r600 = run(600);
const r850 = run(850);

const today = new Date().toISOString().slice(0, 10);
const url = 'https://bracketmath.co.uk/guides/ir35-explained';
