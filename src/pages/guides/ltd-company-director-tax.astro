---
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { optimiseSalaryDividend } from '../../lib/optim/salary-dividend';

const money = (n: number) => '£' + Math.round(n).toLocaleString('en-GB');
const pct = (n: number) =>
  (n * 100).toLocaleString('en-GB', { maximumFractionDigits: 1 }) + '%';

function run(profits: number, opts: { claimEA?: boolean } = {}) {
  return optimiseSalaryDividend({
    profits,
    age: 40,
    pensionWeight: 1.0,
    salaryStep: 100,
    pensionStep: 500,
    claimEmploymentAllowance: !!opts.claimEA,
  });
}

const r50 = run(50_000);
const r75 = run(75_000);
const r100 = run(100_000);
const r140 = run(140_000);
const r200 = run(200_000);

// Employment Allowance comparison at £75k (the rare multi-employee case)
const r75ea = run(75_000, { claimEA: true });

const today = new Date().toISOString().slice(0, 10);
const url = 'https://bracketmath.co.uk/guides/ltd-company-director-tax';
